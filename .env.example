# DOCKER COMPOSE VARIABLES
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=grindifydb
POSTGRES_PORT=5432
BACKEND_PORT=1337
FRONTEND_PORT=3000

## BACKEND ##
# The backend DB variables below reference the Docker Compose variables above for DRY configuration
DATABASE_HOST=postgres
DATABASE_PORT=${POSTGRES_PORT}
DATABASE_USER=${POSTGRES_USER}
DATABASE_PASSWORD=${POSTGRES_PASSWORD}
DATABASE_NAME=${POSTGRES_DB}
JWT_SECRET=change-me

# App defaults (applied to NEWLY registered users)
# true/false (also accepts 1/0, yes/no, on/off)
DEFAULT_SHOW_RPE=true

## FRONTEND ##
VITE_API_URL=http://localhost:1337/v1

# Contact email shown in Terms & Conditions and Privacy Policy
VITE_CONTACT_EMAIL=your@email.com

# Legal notice / Imprint information (shown in Legal Notice dialog)
VITE_OPERATOR_NAME=Your Name or Company Name
VITE_OPERATOR_CITY=Stockholm
VITE_OPERATOR_COUNTRY=Sweden

# Comma-separated list of allowed hosts for Vite dev server
VITE_ALLOWED_HOSTS=localhost

# Comma-separated list of allowed origins for backend CORS
ALLOWED_ORIGINS=http://localhost:3000

# Cookie options for auth (used in AuthExceptionsFilter)
AUTH_COOKIE_DOMAIN= # e.g. leave blank for localhost
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/

# GitHub OAuth — leave blank to disable GitHub login
# Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: http://your-backend/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — leave blank to disable Google login
# Create an OAuth 2.0 Client at https://console.cloud.google.com/apis/credentials
# Set the redirect URI to: http://your-backend/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL of the backend (used as OAuth callback base)
BACKEND_URL=http://localhost:1337

# GitHub Releases proxy used by the Settings version history dialog.
# Leave owner/repo blank to disable it.
GITHUB_RELEASES_OWNER=FalkenDev
GITHUB_RELEASES_REPO=Grindify
GITHUB_RELEASES_TOKEN=

# Email (Resend) — get your API key at resend.com
# Set REQUIRE_EMAIL_VERIFICATION=true to require email verification before login.
# When false (default), users are auto-verified on registration (no email needed).
REQUIRE_EMAIL_VERIFICATION=false
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=http://localhost:3000
